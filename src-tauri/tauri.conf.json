{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-boilerplate",
  "version": "0.0.0",
  "identifier": "com.abdulquadir.tauri-boilerplate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tauri Boilerplate By Abdul Quadir",
        "devtools": false,
        "maximized": true,
        "visible": false,
        "backgroundColor": "#0f172a",
        "decorations": false
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 420,
        "height": 260,
        "decorations": false,
        "transparent": true,
        "center": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "dmg",
      "msi"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "webkit2gtk-4.1",
          "libssl-dev"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
